{
  "name": "@neurall.build/implit",
  "version": "1.2.1",
  "description": "Catch AI hallucinated dependencies and imports before they break your code",
  "type": "module",
  "bin": {
    "implit": "./dist/index.js",
    "hcatch": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts"
  },
  "keywords": [
    "ai",
    "hallucination",
    "dependency",
    "npm",
    "linter",
    "cli"
  ],
  "author": "Neurall",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "ts-morph": "^28.0.0"
  }
}
